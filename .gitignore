# ============================================================
# Enterprise Homelab - .gitignore
# ============================================================
# Convention: ignore secrets, OS junk, editor metadata,
# build artifacts and any local-only state.

# -----------------------------
# Secrets & credentials
# -----------------------------
# NEVER commit secrets. If you find a *.secret pattern in a
# future tool, add it here BEFORE committing anything.
*.key
*.pem
*.p12
*.pfx
*.env
.env
.env.*
!.env.example
secrets/
vault-password*
*.kdbx

# Ansible
*.retry
inventory/host_vars/*/vault.yml
inventory/group_vars/*/vault.yml

# SSH keys (defense in depth)
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts

# -----------------------------
# Operating system junk
# -----------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS (por si en algún momento usas Mac)
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory
.Trash-*

# -----------------------------
# Editors & IDEs
# -----------------------------
# VS Code
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json.example

# JetBrains
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# -----------------------------
# Logs and temporary files
# -----------------------------
*.log
*.tmp
*.bak
*.old
tmp/
temp/

# -----------------------------
# Python (for future scripts)
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/

# -----------------------------
# Node (in case any tooling uses it)
# -----------------------------
node_modules/
npm-debug.log*

# -----------------------------
# Docker
# -----------------------------
# Real compose files are committed; local overrides are NOT
docker-compose.override.yml
.docker/

# -----------------------------
# Terraform (future cloud phase)
# -----------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# -----------------------------
# Project-specific
# -----------------------------
# Local notes that should NOT be public
notes/private/
docs/private/
scratch/
TODO.local.md
